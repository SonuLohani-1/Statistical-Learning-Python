    "7 Solution:\n",
    "\n",
    "Probability of giving dividend\n",
    "P(D = Y) = 0.8\n",
    "\n",
    "Probability of not giving dividend\n",
    "P(D = N) = 0.2\n",
    "\n",
    "Distribution of x given, dividend was given\n",
    "P(X|D=Y) = N(mean = 10, variance = 36)\n",
    "\n",
    "Distribution of x given, divdend was not given\n",
    "P(X|D=N) = N(mean = 0, variance = 36)"
   ]
  },
